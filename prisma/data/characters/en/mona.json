  "elementalSkills": [
    {
      "unlock": "DEFAULT_UNLOCK",
      "name": "Mirror Reflection of Doom",
      "note" : "Skilled astrologers have always dreamed of using a phantom facsimile of themselves to ward off imminent ill fate, but Mona must be the first to make such a mockery of it in all of Teyvat.",
      "descriptions": [
        {"title": null, "description": "Creates an illusory Phantom of Fate from coalesced waterspouts."},
        {"title": "Phantom", "description": "Has the following special properties: - Continuously taunts nearby opponents, attracting their fire. - Continuously deals Hydro DMG to nearby opponents. - When its duration expires, the Phantom explodes, dealing AoE Hydro DMG."},
        {"title": "Hold", "description": "Utilizes water currents to move backwards swiftly before conjuring a Phantom. \nOnly one Phantom created by Mirror Reflection of Doom can exist at any time."}
      ],
      "upgrades": [
